(all x all y all z all u
	((incomparable(x, y)
	& incomparable(y, z)
	& incomparable(x, z)
	& incomparable(x, u)
	& incomparable(y, u)
	& incomparable(z, u)
	->
	dhm3(x, y, z, u)
	| dhm3(y, z, u, x)
	| dhm3(z, u, x, y)
	| dhm3(u, x, y, z)
	| (exists w
	(glb(x, y, w)
	| glb(y, z, w)
	| glb(x, z, w)
	| glb(x, u, w)
	| glb(y, u, w)
	| glb(z, u, w)))))).

