formulas(assumptions).
all x (leq(x,x)).
all x all y all z (leq(x,y) & leq(y,z) -> leq(x,z)).
all x all y (leq(x,y) & leq(y,x) -> x = y).
all x all y (leq(x,y) | leq(y,x)).
all x all y (lt(x,y) <-> (leq(x,y) & -leq(y,x))).
all x all y (covers(y,x) <-> (lt(x,y) & -exists z (lt(x,z) & lt(z,y)))).
all x all y (lt(x,y) -> exists z (covers(y,z) & leq(x,z))).
all x all y (lt(x,y) -> exists z (covers(z,x) & leq(z,y))).
end_of_list.
